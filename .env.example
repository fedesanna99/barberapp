# REQUIRED IN PRODUCTION — la build si rifiuta di partire senza queste.
# Vedi DEPLOYMENT.md §1 per come ottenerle e impostarle su Vercel.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: hCaptcha site key for anti-bot protection on auth forms.
# When unset, captcha is skipped (useful in dev). See HCAPTCHA_SETUP.md.
# VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# Optional: MapTiler API key for the Discover map tiles.
# When unset, the Discover map falls back to OpenFreeMap (no key, community-run).
# Free tier ~100k loads/month, non-commercial only — upgrade before launch.
# VITE_MAPTILER_KEY=your-maptiler-key

# ── Stripe payments ─────────────────────────────────────────────────────
# Publishable key (client-side). When unset, Stripe payments are silently
# disabled in BookingSheet and only "Paga in loco" is offered.
# Get it from Stripe Dashboard → Developers → API keys → Publishable key.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Below are SERVER-SIDE secrets — DO NOT prefix with VITE_ (Vite would bundle
# them into the client). Set them on Supabase Edge Functions via
# `supabase secrets set STRIPE_SECRET_KEY=...` (see DEPLOYMENT.md §Stripe).
#
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
#
# Optional: restrict CORS on create-payment-intent to your Vercel domain.
# Fallback '*' if not set (acceptable in dev, NOT in production).
# ALLOWED_ORIGIN=https://your-app.vercel.app
